# Copy to .env.local for local overrides. Nothing below is required to run PageCue locally —
# the defaults already use mock providers, local storage, and the synthetic demo novel.

NEXT_PUBLIC_APP_MODE=development

# Public site origin used to resolve absolute URLs (e.g. the social share image). Defaults to
# http://localhost:3000 locally; set this to the deployed origin in production.
NEXT_PUBLIC_SITE_URL=

# mock | google  (default: mock)
BOOK_SEARCH_PROVIDER=mock
# mock | openai | anthropic  (default: mock)
RECAP_PROVIDER=mock
# local | d1  (default: local; d1 not yet implemented)
LIBRARY_REPOSITORY=local
# synthetic | d1  (default: synthetic; d1 not yet implemented)
STORY_SOURCE_REPOSITORY=synthetic

# Optional: enables real book metadata search instead of the mock provider.
GOOGLE_BOOKS_API_KEY=

# Optional: enables a real recap provider instead of the deterministic mock (not yet implemented).
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Optional: only needed once Cloudflare D1/R2 integration is implemented.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_R2_BUCKET=
